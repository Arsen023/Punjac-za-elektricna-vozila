<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<!-- Koren za Zadatak 6: Data/&lt;VehicleId&gt;/&lt;YYYY-MM-DD&gt;/session.csv -->
		<add key="ChargingDataRoot" value="Data" />
	</appSettings>

	<system.serviceModel>
		<bindings>
			<netTcpBinding>
				<!-- Streaming + velike poruke (specifikacija projekta). -->
				<binding name="EvChargerNetTcp"
						 transferMode="Streamed"
						 maxReceivedMessageSize="2147483647"
						 maxBufferSize="2147483647"
						 sendTimeout="00:10:00"
						 receiveTimeout="00:10:00">
					<readerQuotas maxDepth="64"
								  maxStringContentLength="65536"
								  maxArrayLength="2147483647"
								  maxBytesPerRead="65536"
								  maxNameTableCharCount="16384" />
				</binding>
			</netTcpBinding>
		</bindings>

		<services>
			<service name="EVCharger.Server.EVChargerService">
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4000" />
					</baseAddresses>
				</host>

				<endpoint address="EVChargerService"
						  binding="netTcpBinding"
						  bindingConfiguration="EvChargerNetTcp"
						  contract="EVCharger.Common.IEVChargerService" />
			</service>
		</services>
	</system.serviceModel>
</configuration>
